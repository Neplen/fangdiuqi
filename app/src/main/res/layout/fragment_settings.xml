<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Alarm Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="报警设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_disconnect_alarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="断连自动报警"
            android:textSize="14sp"
            android:checked="true"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ringtone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择报警铃声"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="16dp" />

        <!-- DND Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="勿扰模式"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_wifi_dnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WIFI 勿扰模式（连接 WiFi 时不报警）"
            android:textSize="14sp"
            android:checked="false"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_schedule_dnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="定时勿扰模式"
            android:textSize="14sp"
            android:checked="false"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="开始时间"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_start_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="21:00"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_set_start_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="设置开始时间"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="结束时间"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_end_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_set_end_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="设置结束时间"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="16dp" />

        <!-- Background Keepalive -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="后台保活"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_battery_optimization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="电池优化设置"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_auto_start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="自启动设置"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="提示：为了保持后台持续运行，请在上述设置中开启自启动并关闭电池优化"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp" />

        <!-- 出门提醒功能（移到底部，保护隐私） -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="出门提醒"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_go_out_reminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="开启出门提醒"
            android:textSize="14sp"
            android:checked="false"
            android:layout_marginBottom="12dp" />

        <!-- 家庭WiFi SSID（只读显示，点击弹出对话框编辑） -->
        <LinearLayout
            android:id="@+id/layout_home_wifi_ssid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="家庭 WiFi 名称 (SSID)"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_home_wifi_ssid_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未设置"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_edit"
                android:contentDescription="编辑" />
        </LinearLayout>

        <!-- 家庭路由器BSSID（只读显示，点击弹出对话框编辑） -->
        <LinearLayout
            android:id="@+id/layout_home_wifi_bssid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="家庭路由器 MAC 地址 (BSSID)"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_home_wifi_bssid_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未设置"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_edit"
                android:contentDescription="编辑" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_go_out_ringtone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择出门提醒铃声"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>