<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.monkeycode.blelostfinder.ui.home.HomeFragment"
        android:label="Home" />

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.monkeycode.blelostfinder.ui.settings.SettingsFragment"
        android:label="Settings" />

    <fragment
        android:id="@+id/navigation_scan"
        android:name="com.monkeycode.blelostfinder.ui.scan.ScanFragment"
        android:label="Scan" />

    <action
        android:id="@+id/action_scan"
        app:destination="@id/navigation_scan" />

</navigation>
